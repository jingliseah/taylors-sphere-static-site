{% extends "@partials::_layout.twig" %}

{% block main %}
	<div class="smooth-scroll">
        <div class="panel section section-hero" ref="heroSection">
            <div class="scene">
                <div class="decorations-container">
                    <img src="~@/assets/img/hero-section/slices/taylors-sphere-logo.png" alt="decoration" class="decoration taylors-sphere-logo">
                    <img src="~@/assets/img/hero-section/slices/pool.png" alt="decoration" class="decoration pool">
                    <img src="~@/assets/img/hero-section/slices/floor-4.png" alt="decoration" class="decoration floor-4">
                    <img src="~@/assets/img/hero-section/slices/floor-1.png" alt="decoration" class="decoration floor-1">
                    <img src="~@/assets/img/hero-section/slices/floor-2.png" alt="decoration" class="decoration floor-2">
                    <img src="~@/assets/img/hero-section/slices/floor-3.png" alt="decoration" class="decoration floor-3">
                    <img src="~@/assets/img/hero-section/slices/sky.png" alt="decoration" class="decoration sky">
                    <img src="~@/assets/img/hero-section/slices/clouds.png" alt="decoration" class="decoration clouds">
                    <img src="~@/assets/img/hero-section/slices/red-element.png" alt="decoration" class="decoration red-element">
                    <img src="~@/assets/img/hero-section/slices/basketball.png" alt="decoration" class="decoration basketball">
                    <img src="~@/assets/img/hero-section/slices/roof-and-tree.png" alt="decoration" class="decoration roof-and-tree">
                    <img src="~@/assets/img/hero-section/slices/block-a.png" alt="decoration" class="decoration block-a">
                    <img src="~@/assets/img/hero-section/slices/block-c-d-e.png" alt="decoration" class="decoration block-c-d-e">
                    <img src="~@/assets/img/hero-section/slices/medicine-students.png" alt="decoration" class="decoration medicine-students">
                    <img src="~@/assets/img/hero-section/slices/drone.png" alt="decoration" class="decoration drone">
                    <img src="~@/assets/img/hero-section/slices/duckie.png" alt="decoration" class="decoration duckie">
                    <img src="~@/assets/img/hero-section/slices/orange-element.png" alt="decoration" class="decoration orange-element">
                    <img src="~@/assets/img/hero-section/slices/wood-work.png" alt="decoration" class="decoration wood-work">
                    <img src="~@/assets/img/hero-section/slices/robotics.png" alt="decoration" class="decoration robotics">
                    <img src="~@/assets/img/hero-section/slices/3d-printers.png" alt="decoration" class="decoration threed-printers">
                    <img src="~@/assets/img/hero-section/slices/students-1.png" alt="decoration" class="decoration students-1">
                    <img src="~@/assets/img/hero-section/slices/students-2.png" alt="decoration" class="decoration students-2">
                    <img src="~@/assets/img/hero-section/slices/students-3.png" alt="decoration" class="decoration students-3">
                    <img src="~@/assets/img/hero-section/slices/uni-square.png" alt="decoration" class="decoration uni-square">
                    <img src="~@/assets/img/hero-section/slices/art.png" alt="decoration" class="decoration art">
                </div>
            </div>
		</div>

		<section id="section-about-us" class="section-about-us">
			<div class="container py-5">
                <div class="mb-4 mb-md-5 d-flex justify-content-center justify-content-lg-start">
                    <div class="line-vertical"></div>
                    <h2 class="title ps-md-4 py-3 ms-3 ms-md-4">Venture into Taylor’sphere<sup>&trade;</sup></h1>
                </div>
                <div class="px-3 px-md-0">
                    <generic-carousel :space-between="32" :slides-per-view="1" :slides-per-view-md="2" :has-navigation="{{ aboutUs|length > 2 }}">
                        <template #carousel-slides>
                            {% for i, item in aboutUs %}
                            <div class="swiper-slide">
                                <card-carousel
                                    @link-click="showVideoModal('{{ item.link }}')"
                                    title="{{ item.title }}"
                                    description="{{ item.description }}"
                                    link="{{ item.link }}">
                                    <template #thumbnail>
                                        <img src="{{ item.thumbnail }}" alt="">
                                    </template>
                                </card-carousel>
                            </div>
                            {% endfor %}
                        </template>
                    </generic-carousel>
                </div>
            </div>
		</section>

        <section id="section-intellect" class="panel section-intellect" ref="intellectSection">
            <div class="summary col-12 col-md-3 text-center text-md-end ms-auto px-5 pt-6 pe-md-6 px-md-0" data-scroll data-scroll-speed="1">
                <h1 class="summary_list_item title">Intel<span class="text-red">lect</span></h1>
                <p class="summary_list_item description px-2 px-md-2">Taylor's Curriculum Framework offers a strong foundation with mix-and-match modules, industry placements, Borderless Learning, and more.</p>   
            </div>
            
            <div class="main-kv-container floating-md-2 animated" data-scroll data-scroll-duration="3">
                <img class="small-ring-1 rings" src="~@/assets/img/intellect-section/small-ring-1.svg" alt="Small Ring">
                <img class="small-ring-2 rings" src="~@/assets/img/intellect-section/small-ring-2.svg" alt="Small Ring">
                <img class="red-circle" src="~@/assets/img/intellect-section/red-circle.svg" alt="Red Circle">
                <img class="blurp" src="~@/assets/img/intellect-section/blurp.png" alt="Main KV">
                <div class="main-kv">
                    <img src="~@/assets/img/intellect-section/main-kv.png" alt="Main KV">
                </div>
                <img class="dots-element-1" src="~@/assets/img/intellect-section/dots-element.png" alt="Main KV">
                <img class="dots-element-2" src="~@/assets/img/intellect-section/dots-element.png" alt="Main KV">
            </div>
        </section>

        <section id="section-craft" class="panel section-craft" ref="craftSection">
            <div class="summary col-12 col-md-3 text-center text-md-end ms-auto px-5 pt-6 pe-md-6 px-md-0">
                <h1 class="summary_list_item title">Cra<span class="text-red">ft</span></h1>
                <p class="summary_list_item description px-2 px-md-0">Nurture your creativity through Taylor’s Me.reka Makerspace, BizPod, & Research and Enterprise.</p>   
            </div>
            
            <div class="main-kv-container floating-md-2 animated">
                <img class="small-ring-1 rings" src="~@/assets/img/craft-section/small-ring-1.svg" alt="Small Ring">
                <img class="small-ring-2 rings" src="~@/assets/img/craft-section/small-ring-2.svg" alt="Small Ring">
                <img class="small-ring-3 rings" src="~@/assets/img/craft-section/small-ring-3.svg" alt="Small Ring">
                <img class="red-circle" src="~@/assets/img/craft-section/red-circle.svg" alt="Red Circle">
                <img class="blurp" src="~@/assets/img/craft-section/blurp.png" alt="Main KV">
                <div class="main-kv">
                    <img src="~@/assets/img/craft-section/main-kv.png" alt="Main KV">
                </div>
                <img class="dots-element-1" src="~@/assets/img/craft-section/dots-element.png" alt="Main KV">
                <img class="dots-element-2" src="~@/assets/img/craft-section/dots-element.png" alt="Main KV">
            </div>
        </section>

        <section id="section-practical-wisdom" class="panel section-practical-wisdom d-flex flex-column justify-content-start" ref="practicalWisdomSection">
            <div class="summary col-12 col-md-3 text-center text-md-end ms-auto px-5 pt-6 pe-md-6 px-md-0">
                <h1 class="summary_list_item title">Practical<br><span class="text-red">Wisdom</span></h1>
                <p class="summary_list_item description px-2 px-md-0">Build skillsets for the working world through Life Skills modules, guided by specialised moderators.</p>   
            </div>
            
            <div class="main-kv-container floating-md-2 animated">
                <img class="small-ring-2 rings" src="~@/assets/img/practical-wisdom-section/small-ring-2.svg" alt="Small Ring">
                <img class="small-ring-3 rings" src="~@/assets/img/practical-wisdom-section/small-ring-3.svg" alt="Small Ring">
                <img class="small-ring-4 rings" src="~@/assets/img/practical-wisdom-section/small-ring-4.svg" alt="Small Ring">
                <img class="red-circle" src="~@/assets/img/practical-wisdom-section/red-circle.svg" alt="Red Circle">
                <img class="blurp" src="~@/assets/img/practical-wisdom-section/blurp.png" alt="Main KV">
                <div class="main-kv">
                    <img src="~@/assets/img/practical-wisdom-section/main-kv.png" alt="Main KV">
                </div>
                <img class="dots-element-1" src="~@/assets/img/practical-wisdom-section/dots-element.png" alt="Main KV">
                <img class="dots-element-2" src="~@/assets/img/practical-wisdom-section/dots-element.png" alt="Main KV">
                <img class="small-ring-1 rings d-none d-md-block" src="~@/assets/img/practical-wisdom-section/small-ring-1.svg" alt="Small Ring">
            </div>
        </section>

        <section class="panel section-ts-components-intro" ref="tsIntroSection">
            <h2 class="title text-center">
                <span class="line-1">TAYL<span class="t-red">O</span>R'SPHERE</span>
                <span class="line-2 t-red">COMPONENTS</span>
            </h2>
        </section>

        <section id="section-taylor-sphere-components" class="section-taylor-sphere-components" ref="sectionComponents">
            <h-scroller id="h-scroll-ts" 
                v-if="isScrollTriggerReady" 
                @card-click="showComponentsModal"
                @ready="handleHScrollRead($event)">
            </h-scroller>
        </section>

        <section id="section-testimonial" class="section-testimonial pb-5">
            <div class="h-100 position-relative">
                <div class="summary align-center d-md-flex justify-content-center text-center text-md-start w-100 pt-5 pt-md-6">
                    <h1 class="summary_list_item title pt-md-3" data-scroll data-scroll-speed='1'>
                        <span>Student</span><br>
                        <span class="text-red">Testimonials</span>
                    </h1>
                    <div class="col-12 col-md-4 ms-md-5 summary_list_item px-5 px-md-0 pt-md-3" data-scroll data-scroll-speed='1.5'>
                        <p class="mb-2 pt-md-3">Everyone experiences Taylor’sphere in their own one-of-a-kind way. Find out what some of our students think!</p> 
                    </div>
                </div>

                <student-carousel @read-more="showStudentTestimonialModal">
                    <template #carousel-slides-main>
                        {% verbatim %}
                            <div class="student-testimonial-slider__item swiper-slide h-100" v-for="(item, index) in students" :key="index">
                                <div class="container-fluid px-0">
                                    <div class="row flex-column-reverse flex-md-row">
                                        <div class="col-12 col-md-5 pb-3 pb-md-0">
                                            <div class="student-testimonial-slider__img" @click.prevent="showStudentTestimonialModal(item)" >
                                                <img :class="{'bg-white': index % 2 === 0, 'bg-gray-300': index % 2 !== 0 }" :src="item.avatar" alt="student 1">
                                            </div>
                                        </div>
                                        <div class="col-12 col-md-7 pt-5 pt-md-0">
                                            <div class="student-testimonial-slider__content">
                                                <div class="student-testimonial-slider__title"><span class="text-clamp">{{ item.summary }}</span></div>
                                                <cite class="student-testimonial-slider__text">— <span class="t-red" v-html="item.name"></span> // <span v-html="item.programme"></span></cite>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endverbatim %}
                    </template>
                </student-carousel>
            </div>
        </section>
        
