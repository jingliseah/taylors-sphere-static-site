        <section v-if="!hideStudentVideoSection" id="section-about-student" class="section-about-student">
			<div class="container py-5 position-relative">
                <div class="mb-4 mb-md-5 d-flex justify-content-center justify-content-lg-start">
                    <div class="line-vertical"></div>
                    <h2 class="title ps-md-4 py-3 ms-3 ms-md-4">Want to know more about our students?</h1>
                </div>

                <div class="px-3 px-md-0">
                    <generic-carousel :space-between="32" :slides-per-view="2" :has-navigation="{{ aboutStudent|length > 2 }}">
                        <template #carousel-slides>
                            {% for i, item in aboutStudent %}
                            <div class="swiper-slide">
                                <card-carousel
                                    @link-click="showVideoModal('{{ item.link }}')"
                                    title="{{ item.title }}"
                                    description="{{ item.description }}"
                                    link="{{ item.link }}">
                                    <template #thumbnail>
                                        <img src="{{ item.thumbnail }}" alt="">
                                    </template>
                                </card-carousel>
                            </div>
                            {% endfor %}
                        </template>
                    </generic-carousel>             
                </div>
            </div>
		</section>

        <section v-if="!hideArSection" id="section-experience-ar" class="section section-experience-ar pb-5 pt-5 pb-md-6">
            <div class="container-fluid pb-4 px-md-6 pt-md-6 ea-summary summary">
                <div class="row text-center text-md-start ea-summary_list">
                    <div class="col-12 col-md-4 ea-summary_list_item" data-scroll>
                        <h1 class="title fw-bold">Discover Taylor’sphere<sup>&trade;</sup> <span class="text-red">through AR</span></h1>
                    </div>
                    <div class="col-12 col-md-4 ea-summary_list_item" data-scroll>
                        <p>Welcome! You’re about to go on a virtual tour of Taylor’sphere to explore what our balanced learning ecosystem and community is all about, using the power of augmented reality.</p>
                    </div>
                    <div class="col-12 col-md-4 ea-summary_list_item" data-scroll>
                        <p>Scan the QR code [or tap on the link] to launch the experience, and let’s begin!</p>
                    </div>
                </div>
            </div>

            <div class="container-fluid px-0 px-md-6" data-scroll>
                <iframe class="ea-iframe" src="https://www.youtube.com/embed/zCIr-lbCuXc" title="Iframe Example"></iframe>
            </div>
        </section>

        <section id="section-footer" class="section section-footer">
            <div class="px-4 px-md-5 py-4 py-md-3 mb-4 mb-md-3">
                <div class="d-flex justify-content-between align-items-center flex-column-reverse flex-md-row">
                    <ul class="col-12 col-md-4 list-unstyled d-flex align-items-center justify-content-between justify-content-md-start mb-0">
                        <li class="pe-md-4"><img src="~@/assets/img/icons/logo.png" alt="Taylor Logo" height='65'></li>
                        <li class="text-end text-md-start copyright subheading">© Taylor’s Education Group 2021</li>
                    </ul>
                    <div class="col-12 col-md-8 d-flex justify-content-between align-items-end align-items-md-center pb-5 pb-md-0">
                        <ul class="list-unstyled d-md-flex justify-content-between mb-0">
                            <li class="pb-2 pb-md-0 pe-4"><a class="link subheading" target="_blank" href="https://university.taylors.edu.my/privacy-policy.html">PRIVACY POLICY</a></li>
                            <li class="pb-2 pb-md-0 pe-4"><a class="link subheading" target="_blank" href="https://university.taylors.edu.my/en/terms-conditions.html">TERMS &amp; CONDITIONS</a></li>
                            <li><a class="link subheading" target="_blank" href="https://university.taylors.edu.my/en/about-taylors/contact-us.html">CONTACT US</a></li>
                        </ul>
                        <ul class="list-unstyled d-flex mb-0">
                            <li><a href="https://www.facebook.com/TaylorsUniversityMY" target="_blank"><img src="~@/assets/img/icons/facebook.svg" alt="Facebook"></a></li>
                            <li class="ps-4"><a href="https://www.instagram.com/taylorsuni" target="_blank"><img src="~@/assets/img/icons/instagram.svg" alt="Instagram"></a></li>
                            <li class="ps-4"><a href="https://www.youtube.com/user/taylors" target="_blank"><img src="~@/assets/img/icons/youtube.svg" alt="Youtube"></a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>
	</div>

    <tfm-popup ref="tfmPopup"></tfm-popup>
    
    <a v-if="enableChat" href="https://wa.me/601115688874?text=I'm%20interested%20in%20Taylor's%20Future%20Movement%202021" target="_blank" class="chat">
        <img src="~@/assets/img/icons/chat.svg" alt="">
    </a>

    {# Video Modal #}
    <generic-modal modal-id="videoModal"
        ref="videoModal"
        class="modal-video"
        modal-size="modal-xl"
        @hide="youtubeIframeLink = ''">
        <template #modal-content>
            <div class="ratio ratio-16x9" v-if="youtubeIframeLink">
                <iframe width="560" height="315" :src="youtubeIframeLink" 
                    title="YouTube video player" 
                    frameborder="0" 
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                    allowfullscreen>
                </iframe>
            </div>
        </template>
    </generic-modal>

    {% verbatim %}
        <generic-modal modal-id="testimonial-modal" ref="testimonialModal" class="modal-testimonial" modal-size="modal-lg">
            <template #modal-content>
                <div class="container wrapper g-0" v-if="currentStudent">
                    <div class="row g-0 p-4 p-md-5">
                        <div class="col-12 col-md-6"></div>
                        <div class="col-12 col-md-6">
                            <img class="avatar d-block d-md-none" :src="currentStudent.avatar" :alt="'Picture of ' + currentStudent.name" align="left">
                            <h3 class="name fw-bold"><span class="t-red" v-html="currentStudent.name"></span></h3>
                            <p class="subheading text-muted">{{ currentStudent.programme }}</p>
                            <div v-html="currentStudent.description"></div>
                        </div>
                    </div>
                    <div class="row g-0 bg-red">
                        <div class="col-12 col-md-6 position-relative">
                            <img class="avatar d-none d-md-block" :src="currentStudent.avatarModal" alt="">
                        </div>

                        <div class="col-12 col-md-6 px-5 py-5 ps-md-0" v-if="!hideStudentVideoSection">
                            <div class="thumbnail" @click="showStudentTestimonialVideoModal()">
                                <div class="icon">
                                    <img src="~@/assets/img/icons/play.svg" alt="Play">
                                </div>
                                <div class="overlay"></div>
                                <div class="ratio ratio-16x9">
                                    <img :src="currentStudent.thumbnail" :alt="'Video testimonial of ' + currentStudent.name">
                                </div>
                            </div>  
                        </div>
                    </div>
                </div>
            </template>
        </generic-modal>

        <generic-modal 
            modal-id="testimonial-video-modal" 
            ref="testimonialVideoModal" 
            class="modal-video modal-testimonial-video"
            modal-size="modal-lg">
            <template #modal-content>
                <div class="ratio ratio-16x9" v-if="currentStudent">
                    <iframe width="560" height="315" :src="currentStudent.video" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                </div>
            </template>
        </generic-modal>
    {% endverbatim %}

    {% for i,item in components %}
        <generic-modal modal-id="components-modal-{{i}}" ref="componentsModal{{i}}" class="modal-components modal-components-{{i}}" modal-size="modal-lg">
            <template #modal-content>
                <div class="px-3 px-5">
                    <div class="row">
                        <div class="col-12">
                            <h1 class="title text-center pb-5 text-uppercase">{{item.title}}</h1>
                            <img class="content-img pb-5" src="{{item.image}}" alt="">
                        </div>
                    </div>
                    <div class="row px-3 px-md-0">
                        <div class="col-12">
                            <div class="pb-5 text-center text-md-start">{{item.description|raw}}</div>
                            <div class="d-flex justify-content-center pb-5">
                                <a href="{{item.link}}" target="_blank">
                                    <button type="button" class="btn btn-primary text-white text-uppercase fw-bold">Find Out More</button>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="px-3">
                    <div class="row  mb-6" v-if="!hideTfmEvents">
                        <div class="col-12">
                            <p class="fw-bold text-center fs-5">YOU MAY BE INTERESTED IN</p>
                        </div>
                        <div class="row g-0 px-3">
                            <div class="col-12" v-if="closestUpcomingWeek">
                                <div class="row">
                                    <div class="col-md-6 mb-2" v-for="item in getAgendaSuggestions('{{ item.id }}')">
                                        {% verbatim %}
                                            <div class="card card-event h-100" :style="{
                                                '--card-color': getCategoryColor(item.category),
                                                '--card-g1-color': hexToRGB(getCategoryColor(item.category), 0.5),
                                                '--card-g2-color': hexToRGB(getCategoryColor(item.category), 0),
                                            }">
                                                <div class="card-emblem">
                                                    <time class="date">
                                                        <span class="month">{{ formatISODate(getEventDate(item), 'MMM') }}</span>
                                                        <span class="day">{{ formatISODate(getEventDate(item), 'D') }}</span>
                                                    </time>
                                                </div>
                                                <div class="card-image ratio-4x3">
                                                    <img :src="getAdjustedImageLink(item.keyVisual.Url)" :alt="'Image of ' + item.title">
                                                </div>
                                                <div class="card-body">
                                                    <h3 class="card-title"><a target="_blank" :href="'/taylorsphere/taylors-future-movement/#event-' + item.id" class="stretched-link">{{ item.title }}</a></h3>
                                                    <p class="card-caption" v-if="item.medium">{{ item.medium.Name }}</p>
                                                    <div class="flex-grow-1"></div>
                                                    <div class="timestamp">
                                                        <svg v-svg symbol="sprite-clock" class="icon"></svg>
                                                        {{ getEventTiming (item) }}
                                                    </div>
                                                </div>
                                            </div>
                                            
                                        {% endverbatim %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </template>
        </generic-modal>
    {% endfor %}

    {# END MODALS #}

{% endblock %}
